{
  "name": "work-portal-v2",
  "version": "1.0.0",
  "description": "업무Portal v2 — Electron Desktop App",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start":   "electron .",
    "dev":     "NODE_ENV=development electron .",
    "build":   "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "kr.archsafe.work-portal-v2",
    "productName": "업무Portal",
    "copyright":   "Copyright © 2026 Kevin",
    "files": [
      "src/**/*",
      "core/**/*",
      "engine/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis",     "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon":   "assets/icon.icns"
    },
    "nsis": {
      "oneClick":          false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["Korean"]
    },
    "asar": true,
    "asarUnpack": ["**/better-sqlite3/**"]
  }
}
